# Copy this file to .env and fill in your own values.
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env (Windows cmd)
# Never commit the real .env — it is gitignored.

# --- Secrets ---------------------------------------------------------------
# Groq API key (https://console.groq.com) - powers the cascadeflow LLM analysis
GROQ_API_KEY=

# GitHub personal access token with Actions: read (and repo access if private)
GITHUB_TOKEN=

# Hindsight API key (only needed if using a hosted Hindsight service; the
# default file-based memory does not require this)
HINDSIGHT_API_KEY=

# --- Optional configuration (sensible defaults shown) ----------------------
# Cascadeflow model routing
FAST_MODEL=llama-3.1-8b-instant
REASONING_MODEL=llama-3.3-70b-versatile

# Persistence file paths
STORE_PATH=failure_store.json
HINDSIGHT_PATH=hindsight_db.json

# CORS origins for the frontend (comma-separated). Default allows all.
# Example: CORS_ORIGINS=http://localhost:5173,https://your-frontend.example
CORS_ORIGINS=*
